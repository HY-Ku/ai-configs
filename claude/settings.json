{
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "{{CLAUDE_HOME}}/hooks/record-prompts.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "{{CLAUDE_HOME}}/hooks/rtk-rewrite.sh"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash {{CLAUDE_HOME}}/statusline-command.sh"
  },
  "effortLevel": "high",
  "model": "opus"
}
